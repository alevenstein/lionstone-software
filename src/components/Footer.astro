---
import { SITE_TITLE } from '../consts';
const today = new Date();
---

<footer>
	<div class="inner">
		<div class="brand-line">
			<span class="brand-mark" aria-hidden="true">&#9819;</span>
			<span>{SITE_TITLE}</span>
		</div>
		<nav aria-label="Footer">
			<a href="/">Home</a>
			<a href="/showcase">Showcase</a>
			<a href="/about">About</a>
			<a href="/privacy">Privacy</a>
		</nav>
		<p class="copy">&copy; {today.getFullYear()} {SITE_TITLE}. All rights reserved.</p>
	</div>
</footer>
<style>
	footer {
		border-top: 1px solid var(--border);
		background: var(--bg-elevated);
		padding: 2.5rem 1.25rem;
		color: var(--text-muted);
	}
	.inner {
		max-width: var(--max-width);
		margin: 0 auto;
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}
	.brand-line {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		color: var(--text);
		font-weight: 700;
	}
	.brand-mark {
		display: inline-grid;
		place-items: center;
		width: 24px;
		height: 24px;
		border-radius: 6px;
		background: var(--accent);
		color: #1a1206;
		font-size: 0.85rem;
		font-weight: 700;
	}
	nav {
		display: flex;
		gap: 1.25rem;
		flex-wrap: wrap;
	}
	nav a {
		color: var(--text-muted);
		text-decoration: none;
		font-size: 0.95rem;
	}
	nav a:hover { color: var(--accent); }
	.copy {
		margin: 0;
		font-size: 0.85rem;
		color: var(--text-dim);
	}
	@media (max-width: 720px) {
		.inner { flex-direction: column; align-items: flex-start; }
	}
</style>
