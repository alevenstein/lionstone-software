---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

type Props = CollectionEntry<'showcase'>['data'];

const { title, tagline, summary, platforms, status, year, heroImage, links } = Astro.props;

const platformLabels: Record<string, string> = {
	web: 'Web',
	android: 'Android',
	ios: 'iOS',
	desktop: 'Desktop',
	macos: 'macOS',
	windows: 'Windows',
	linux: 'Linux',
};
const statusLabels: Record<string, string> = {
	'live': 'Live',
	'beta': 'Beta',
	'in-development': 'In development',
	'archived': 'Archived',
};

const linkDefs: Array<{ key: keyof typeof links; label: string; primary?: boolean }> = [
	{ key: 'play', label: 'Play now', primary: true },
	{ key: 'playStore', label: 'Google Play' },
	{ key: 'appStore', label: 'App Store' },
	{ key: 'site', label: 'Visit site' },
	{ key: 'source', label: 'Source code' },
];
const ctaLinks = linkDefs
	.map((def) => ({ ...def, url: links?.[def.key] }))
	.filter((b): b is typeof b & { url: string } => Boolean(b.url));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${title} — Lionstone Software`} description={summary} image={heroImage} />
	</head>
	<body>
		<Header />
		<main>
			<article>
				<header class="entry-header">
					<a class="back" href="/showcase">&larr; All projects</a>
					<div class="entry-meta">
						<span class={`badge status-${status}`}>{statusLabels[status]}</span>
						<span class="year">{year}</span>
						{platforms.map((p) => <span class="badge">{platformLabels[p] ?? p}</span>)}
					</div>
					<h1>{title}</h1>
					<p class="tagline">{tagline}</p>
					{ctaLinks.length > 0 && (
						<div class="cta-row">
							{ctaLinks.map((b) => (
								<a
									class={`btn ${b.primary ? 'btn-primary' : 'btn-ghost'}`}
									href={b.url}
									target="_blank"
									rel="noopener"
								>
									{b.label}
								</a>
							))}
						</div>
					)}
				</header>

				{heroImage && (
					<div class="hero">
						<img src={heroImage} alt="" width={1280} height={720} />
					</div>
				)}

				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
		<style>
			.entry-header {
				max-width: var(--prose-width);
				margin: 0 auto 2rem;
				padding: 1rem 0 0;
			}
			.back {
				display: inline-block;
				color: var(--text-muted);
				font-size: 0.9rem;
				margin-bottom: 1.25rem;
			}
			.back:hover { color: var(--accent); }
			.entry-meta {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				margin-bottom: 1rem;
			}
			.entry-meta .year {
				font-size: 0.8rem;
				color: var(--text-dim);
				align-self: center;
			}
			.tagline {
				font-size: 1.25rem;
				color: var(--text-muted);
				margin: 0.5rem 0 1.5rem;
			}
			.cta-row {
				display: flex;
				flex-wrap: wrap;
				gap: 0.6rem;
			}
			.hero {
				max-width: var(--max-width);
				margin: 0 auto 2.5rem;
			}
			.hero img {
				width: 100%;
				border-radius: var(--radius-lg);
				border: 1px solid var(--border);
			}
			.prose :global(h2) {
				margin-top: 2rem;
				font-size: 1.6rem;
			}
			.prose :global(h3) { margin-top: 1.5rem; }
			.prose :global(ul) { padding-left: 1.25rem; }
			.prose :global(li) { margin: 0.35rem 0; }
		</style>
	</body>
</html>
