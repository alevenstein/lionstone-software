---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';

const pageTitle = `About — ${SITE_TITLE}`;
const pageDescription = `About ${SITE_TITLE}, an indie studio building small web and Android games and the occasional useful app.`;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} />
	</head>
	<body>
		<Header />
		<main>
			<section class="intro">
				<span class="eyebrow">About</span>
				<h1>A small studio with a short list.</h1>
				<p class="lede">
					Lionstone Software is an independent studio. We build games for the web and
					Android, plus a small selection of apps we wished existed. We are deliberately
					small so we can ship things we are proud of.
				</p>
			</section>

			<section class="prose">
				<h2>What we build</h2>
				<p>
					Our games tend to be short, replayable, and respectful of your time — roguelikes
					you can finish on a coffee break, puzzlers you can pick up between meetings.
					Our apps are quiet utilities: focus tools, notebooks, the kind of software that
					tries to disappear once it has done its job.
				</p>

				<h2>How we work</h2>
				<p>
					We prototype quickly, ship small, and iterate based on what real players tell us.
					Most projects share a single TypeScript core that we wrap for web and Android.
					When something needs native horsepower, we reach for Rust or Kotlin and keep the
					rest of the stack the same.
				</p>

				<h2>What we won't do</h2>
				<ul>
					<li>No pay-to-win mechanics. Our games are bought once or are free with no upsell.</li>
					<li>No streak shame. Our apps don't punish you for missing a day.</li>
					<li>No tracking beyond what's needed to keep the lights on.</li>
				</ul>

				<h2>Get in touch</h2>
				<p>
					We're always happy to hear from players, fellow developers, and the curious.
					Reach us at <a href="mailto:hello@lionstone.example">hello@lionstone.example</a>.
				</p>
			</section>
		</main>
		<Footer />
		<style>
			.intro {
				padding: 3rem 0 2rem;
				max-width: 820px;
			}
			.intro h1 { margin: 0 0 1rem; }
			.lede {
				font-size: 1.15rem;
				color: var(--text-muted);
				margin: 0 0 1rem;
			}
			.prose {
				max-width: var(--prose-width);
				margin: 1rem 0 0;
			}
			.prose h2 { margin-top: 2rem; font-size: 1.5rem; }
			.prose ul { padding-left: 1.25rem; }
			.prose li { margin: 0.35rem 0; }
		</style>
	</body>
</html>
