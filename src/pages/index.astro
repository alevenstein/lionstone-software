---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ShowcaseCard from '../components/ShowcaseCard.astro';
import { SITE_TITLE, SITE_DESCRIPTION, SITE_TAGLINE } from '../consts';
import { getCollection } from 'astro:content';

const allEntries = await getCollection('showcase');
const featured = allEntries
	.filter((e) => e.data.featured)
	.sort((a, b) => a.data.order - b.data.order);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<span class="eyebrow">Indie studio · est. 2024</span>
				<h1>{SITE_TAGLINE}</h1>
				<p class="lede">
					Lionstone Software is a small studio building web and Android games — and the
					occasional useful app. We ship things we'd want to play or use ourselves.
				</p>
				<div class="hero-cta">
					<a class="btn btn-primary" href="/showcase">See our work &rarr;</a>
					<a class="btn btn-ghost" href="/about">About the studio</a>
				</div>
			</section>

			<section class="featured">
				<div class="section-head">
					<h2>Featured projects</h2>
					<a class="see-all" href="/showcase">See all &rarr;</a>
				</div>
				<div class="grid">
					{featured.map((entry) => <ShowcaseCard entry={entry} />)}
				</div>
			</section>

			<section class="pillars">
				<div class="pillar">
					<h3>Small games, fully formed</h3>
					<p class="muted">
						We'd rather ship a tight 10-minute roguelike than promise the next open-world
						epic. Our games are designed to fit a coffee break.
					</p>
				</div>
				<div class="pillar">
					<h3>Mobile and web, side by side</h3>
					<p class="muted">
						Most projects ship to Android and the open web from a shared core. Pick the
						platform you have in your pocket.
					</p>
				</div>
				<div class="pillar">
					<h3>Quiet, calm software</h3>
					<p class="muted">
						No streak shame. No dark patterns. No engagement loops dressed up as features.
						Just things that earn their place on your home screen.
					</p>
				</div>
			</section>
		</main>
		<Footer />
		<style>
			.hero {
				padding: 4rem 0 3rem;
				max-width: 820px;
			}
			.hero h1 {
				margin: 0 0 1rem;
			}
			.lede {
				font-size: 1.2rem;
				color: var(--text-muted);
				max-width: 640px;
				margin: 0 0 2rem;
			}
			.hero-cta {
				display: flex;
				flex-wrap: wrap;
				gap: 0.75rem;
			}
			.featured {
				padding: 2rem 0 3rem;
				border-top: 1px solid var(--border);
				margin-top: 1rem;
			}
			.section-head {
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				gap: 1rem;
				margin: 1.5rem 0 1.5rem;
			}
			.section-head h2 { margin: 0; }
			.see-all { font-size: 0.95rem; font-weight: 700; }
			.pillars {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
				gap: 1.5rem;
				padding: 3rem 0 1rem;
				border-top: 1px solid var(--border);
				margin-top: 2rem;
			}
			.pillar h3 { font-size: 1.15rem; margin-bottom: 0.5rem; }
			.pillar p { margin: 0; }
		</style>
	</body>
</html>
